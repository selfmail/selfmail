    "database": "workspace:*",
    "geist": "^1.3.1",
    "next": "^15.1.3",
    "next-safe-action": "^7.10.2",
    "next-themes": "^0.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^1.7.1",
    "ui": "workspace:*",
